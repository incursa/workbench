{
  "Paths": {
    "DocsRoot": "docs",
    "SpecsRoot": "specs",
    "RequirementsDir": "specs/requirements",
    "ArchitectureDir": "architecture",
    "WorkRoot": "work",
    "ItemsDir": "work/items",
    "DoneDir": "work/done",
    "TemplatesDir": "work/templates",
    "WorkboardFile": "work/README.md"
  },
  "Ids": {
    "Width": 4,
    "Prefixes": {
      "Bug": "BUG",
      "Task": "TASK",
      "Spike": "SPIKE"
    }
  },
  "Git": {
    "BranchPattern": "work/{id}-{slug}",
    "CommitMessagePattern": "Promote {id}: {title}",
    "DefaultBaseBranch": "main",
    "RequireCleanWorkingTree": true
  },
  "Github": {
    "Provider": "gh",
    "DefaultDraft": true,
    "Host": "",
    "Owner": "incursa",
    "Repository": "workbench",
    "Sync": {
      "Mode": "generate",
      "ConflictDefault": "fail",
      "ScheduleEnabled": false
    }
  },
  "Validation": {
    "LinkExclude": [],
    "DocExclude": []
  },
  "Tui": {
    "Theme": "dark",
    "UseEmoji": false,
    "AutoRefreshSeconds": 0
  }
}
