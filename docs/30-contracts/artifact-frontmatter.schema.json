{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-frontmatter.schema.json",
  "title": "Artifact Front Matter",
  "description": "Strict reference schema for file-level YAML front matter used by the Markdown artifacts in this package.",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "oneOf": [
    {
      "title": "Specification Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "capability",
        "status",
        "owner"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^SPEC-[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*$"
        },
        "artifact_type": {
          "const": "specification"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "capability": {
          "description": "Capability, behavior area, interface, or technical concern grouped by the specification.",
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": [
            "draft",
            "proposed",
            "approved",
            "implemented",
            "verified",
            "superseded",
            "retired"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "description": "Optional topical tags for search and navigation.",
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "description": "Optional direct artifact IDs for documents materially related to this specification.",
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Architecture Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "satisfies"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^ARC-[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "architecture"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": [
            "draft",
            "proposed",
            "approved",
            "implemented",
            "verified",
            "superseded",
            "retired"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "satisfies": {
          "description": "Requirement IDs satisfied by this architecture or design artifact.",
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "description": "Optional direct artifact IDs for documents materially related to this architecture.",
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Work Item Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "addresses",
        "design_links",
        "verification_links"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^WI-[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "work_item"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": [
            "planned",
            "in_progress",
            "blocked",
            "complete",
            "cancelled",
            "superseded"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "addresses": {
          "description": "Requirement IDs addressed by this work item.",
          "$ref": "#/$defs/stringArray"
        },
        "design_links": {
          "description": "Architecture artifact IDs used as design inputs for this work item.",
          "$ref": "#/$defs/stringArray"
        },
        "verification_links": {
          "description": "Verification artifact IDs associated with this work item.",
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "description": "Optional direct artifact IDs for documents materially related to this work item.",
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Verification Front Matter",
      "type": "object",
      "required": [
        "artifact_id",
        "artifact_type",
        "title",
        "domain",
        "status",
        "owner",
        "verifies"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^VER-[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*-\\d{4,}$"
        },
        "artifact_type": {
          "const": "verification"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "enum": [
            "planned",
            "passed",
            "failed",
            "blocked",
            "waived",
            "obsolete"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verifies": {
          "description": "Requirement IDs verified by this verification artifact.",
          "$ref": "#/$defs/stringArray"
        },
        "related_artifacts": {
          "description": "Optional direct artifact IDs for documents materially related to this verification artifact.",
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    }
  ]
}
