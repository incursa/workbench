{
  "name": "@incursa/workbench-docs-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Cloudflare Worker MCP docs server for Workbench markdown.",
  "type": "commonjs",
  "files": [
    "dist",
    "content",
    "src/mcp",
    "mcp/README.md"
  ],
  "scripts": {
    "build:manifests": "node scripts/generate-mcp.mjs",
    "build:worker": "node scripts/build-mcp.mjs",
    "build:mcp": "npm run build:manifests && npm run build:worker",
    "build": "npm run build:mcp",
    "dev:mcp": "wrangler dev --config wrangler.toml",
    "dev": "npm run dev:mcp",
    "test:mcp": "node --test tests/mcp/transport.test.mjs tests/mcp/tools.test.mjs",
    "test": "npm run build:mcp && npm run test:mcp",
    "verify:mcp": "npm run test",
    "verify": "npm run verify:mcp",
    "deploy:mcp": "npm run build:mcp && wrangler deploy --config wrangler.toml",
    "deploy": "npm run deploy:mcp"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "esbuild": "^0.27.4",
    "gray-matter": "^4.0.3",
    "wrangler": "^4.79.0",
    "zod": "^4.3.6"
  }
}
