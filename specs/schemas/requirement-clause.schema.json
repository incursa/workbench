{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirement-clause.schema.json",
  "title": "Requirement Clause",
  "description": "Reference schema for extracted metadata from a compact requirement clause in a specification document, using the narrowed BCP 14-style uppercase keyword set defined by the standard.",
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "type": "object",
  "required": [
    "requirement_id",
    "title",
    "clause",
    "normative_keyword"
  ],
  "properties": {
    "requirement_id": {
      "type": "string",
      "pattern": "^REQ-[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*-\\d{4,}$"
    },
    "title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "clause": {
      "description": "Normative requirement sentence or short paragraph that appears immediately after the requirement heading and contains exactly one approved all-caps normative keyword phrase from the closed set.",
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "pattern": "\\b(?:MUST NOT|SHALL NOT|SHOULD NOT|MUST|SHALL|SHOULD|MAY)\\b"
        },
        {
          "not": {
            "pattern": "\\b(?:MUST NOT|SHALL NOT|SHOULD NOT|MUST|SHALL|SHOULD|MAY)\\b[\\s\\S]*\\b(?:MUST NOT|SHALL NOT|SHOULD NOT|MUST|SHALL|SHOULD|MAY)\\b"
          }
        }
      ]
    },
    "normative_keyword": {
      "description": "Approved all-caps normative keyword extracted from the clause.",
      "enum": [
        "MUST",
        "MUST NOT",
        "SHALL",
        "SHALL NOT",
        "SHOULD",
        "SHOULD NOT",
        "MAY"
      ]
    },
    "trace": {
      "$ref": "requirement-trace-fields.schema.json"
    },
    "notes": {
      "description": "Optional note lines associated with the requirement.",
      "$ref": "#/$defs/stringArray"
    }
  },
  "additionalProperties": false
}
