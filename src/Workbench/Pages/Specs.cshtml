@page
@model Workbench.Pages.SpecsModel
@{
    ViewData["Title"] = "Specs";
}

<section class="hero inc-card">
    <div class="hero-copy">
        <div class="eyebrow">Specification editor</div>
        <h2>Write and manage repository-native specifications with canonical requirement clauses and stable IDs.</h2>
        <p>
            Specifications stay Markdown-first, but the editor keeps the file shape explicit so Workbench can interpret, link, and refresh them without guesswork.
        </p>
        <div class="muted">@Model.SpecIdPolicySummary</div>
        <div class="hero-links">
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Specs" asp-route-createMode="true" asp-route-query="@Model.Query">Create spec</a>
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Docs">Docs</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Index">Items</a>
        </div>
    </div>
    <div class="hero-stats">
        <div class="inc-card stat-card accent">
            <span class="stat-label">Specs found</span>
            <span class="stat-value">@Model.Specs.Count</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Query</span>
            <span class="stat-value">@(string.IsNullOrWhiteSpace(Model.Query) ? "all" : Model.Query)</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Repo root</span>
            <span class="stat-value">@Model.RepoRoot</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Profile</span>
            <span class="stat-value">@Model.ProfileName</span>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.BannerTitle))
{
    <section class="inc-card panel banner">
        <div class="panel-head compact">
            <h3>@Model.BannerTitle</h3>
        </div>
        @foreach (var line in Model.BannerLines)
        {
            <div class="muted">@line</div>
        }
    </section>
}

<div class="workspace docs-layout">
    <aside class="inc-card panel sidebar">
        <div class="panel-head">
            <h3>Browse specs</h3>
            <form method="get" class="inline-filter docs-filter">
                <input type="hidden" name="selectedReference" value="@Model.SelectedReference" />
                <input type="hidden" name="createMode" value="@Model.CreateMode" />
                <label class="inc-form__group">
                    <span class="field-label">Search</span>
                    <input class="inc-form__control" name="query" value="@Model.Query" placeholder="Artifact ID, title, body, work item" />
                </label>
                <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Apply filters</button>
            </form>
        </div>

        <div class="tree-list">
            @if (Model.Specs.Count == 0)
            {
                <div class="empty-state">No specs match the current filters.</div>
            }
            else
            {
                @await Html.PartialAsync("_TreeBranch", Model.Tree)
            }
        </div>
    </aside>

    <section class="inc-card panel detail">
        @if (Model.SelectedSpec is null && !Model.IsCreateMode)
        {
            <div class="empty-state large">Select a spec to edit it here or start a new one with the create button above.</div>
        }
        else
        {
            <div class="detail-header">
                <div>
                    <div class="eyebrow">@(Model.IsCreateMode ? "Create spec" : "Selected spec")</div>
                    <h3>@(Model.IsCreateMode ? "Create a new specification" : Model.Edit.Title)</h3>
                    <p>@(Model.IsCreateMode ? "Workbench will save the new specification under specs/<domain>/ unless you choose a path." : Model.SelectedSpec!.Summary.Path)</p>
                </div>
                <div class="detail-badges">
                    @if (Model.IsCreateMode)
                    {
                        <span class="pill">specification</span>
                        <span class="pill">create</span>
                    }
                    else
                    {
                        <span class="pill">@Model.SelectedSpec!.Summary.ArtifactId</span>
                        <span class="pill">@Model.SelectedSpec!.Summary.Status</span>
                    }
                </div>
            </div>

            <section class="inc-card snapshot">
                <div class="snapshot-head">
                    <h4>@(Model.IsCreateMode ? "Creation hints" : "Metadata")</h4>
                    <span class="muted">@Model.SpecIdPolicySummary</span>
                </div>
                <div class="link-grid">
                    <div>
                        <div class="field-label">Artifact ID</div>
                        @{
                            var artifactIdDisplay = Model.Edit.ArtifactId;
                            if (string.IsNullOrWhiteSpace(artifactIdDisplay))
                            {
                                artifactIdDisplay = Model.IsCreateMode ? "- (generated on save if policy applies)" : "-";
                            }
                        }
                        <div class="mono">@artifactIdDisplay</div>
                    </div>
                    <div>
                        <div class="field-label">Domain</div>
                        <div class="mono">@(string.IsNullOrWhiteSpace(Model.Edit.Domain) ? "-" : Model.Edit.Domain)</div>
                    </div>
                    <div>
                        <div class="field-label">Capability</div>
                        <div class="mono">@(string.IsNullOrWhiteSpace(Model.Edit.Capability) ? "-" : Model.Edit.Capability)</div>
                    </div>
                    <div>
                        <div class="field-label">Related artifacts</div>
                        @if (Model.IsCreateMode)
                        {
                            <div class="muted">Draft links will appear after save.</div>
                        }
                        else if (Model.SelectedSpec!.Summary.WorkItems.Count == 0)
                        {
                            <div class="muted">None</div>
                        }
                        else
                        {
                            foreach (var id in Model.SelectedSpec.Summary.WorkItems)
                            {
                                <div class="mono">@id</div>
                            }
                        }
                    </div>
                    <div>
                        <div class="field-label">Path</div>
                        <div class="mono">@(Model.IsCreateMode ? "specs/CLI/SPEC-CLI-....md" : Model.SelectedSpec!.Summary.Path)</div>
                    </div>
                    @if (!Model.IsCreateMode)
                    {
                        <div>
                            <div class="field-label">Excerpt</div>
                            <div class="muted">@Model.SelectedSpec!.Summary.Excerpt</div>
                        </div>
                    }
                </div>
            </section>

            <section class="inc-card panel">
                <div class="panel-head compact">
                    <h4>@(Model.IsCreateMode ? "Create spec" : "Edit spec")</h4>
                    <span class="muted">Sections are saved back as Markdown with clickable repository links.</span>
                </div>
                <div class="muted">@(Model.IsCreateMode ? "Leave Artifact ID blank to use the repository policy. Workbench will choose the default specs path from the title when you leave Path empty." : "The editor keeps the structured body and traceability links in sync with the file on disk. Repo doc paths and artifact IDs are converted into clickable links when possible.")</div>

                <form method="post" asp-page-handler="Save" class="editor-stack">
                    <div asp-validation-summary="All" class="validation-summary"></div>
                    <input type="hidden" asp-for="CreateMode" />
                    <input type="hidden" asp-for="Edit.Path" />

                    <section class="inc-card editor-section">
                        <div class="editor-section-head">
                            <h4>Identity</h4>
                            <span class="muted">Stable document identifiers and publishing metadata.</span>
                        </div>
                        <div class="muted">Leave the artifact ID blank to let Workbench regenerate it from the document metadata when you save. For related doc fields, paste a repo path or artifact ID and Workbench will turn it into a clickable link when it can resolve the target.</div>
                        <div class="editor-grid editor-grid-two">
                            <label class="inc-form__group">
                                <span class="field-label">Artifact ID</span>
                                <input class="inc-form__control mono" asp-for="Edit.ArtifactId" placeholder="SPEC-CLI-ONBOARDING" />
                            </label>
                            <label class="inc-form__group">
                                <span class="field-label">Domain</span>
                                <input class="inc-form__control mono" asp-for="Edit.Domain" placeholder="CLI" />
                            </label>
                            <label class="inc-form__group">
                                <span class="field-label">Capability</span>
                                <input class="inc-form__control mono" asp-for="Edit.Capability" placeholder="ONBOARDING" />
                            </label>
                            <label class="inc-form__group">
                                <span class="field-label">Status</span>
                                <input class="inc-form__control" asp-for="Edit.Status" placeholder="draft" />
                            </label>
                            <label class="inc-form__group span-2">
                                <span class="field-label">Title</span>
                                <input class="inc-form__control" asp-for="Edit.Title" />
                            </label>
                            <label class="inc-form__group span-2">
                                <span class="field-label">Owner</span>
                                <input class="inc-form__control" asp-for="Edit.Owner" placeholder="team or person" />
                            </label>
                        </div>
                    </section>

                    <section class="inc-card editor-section">
                        <div class="editor-section-head">
                            <h4>Core narrative</h4>
                            <span class="muted">Purpose, scope, and context frame the grouped requirement clauses.</span>
                        </div>
                        <div class="editor-stack">
                            <label class="inc-form__group">
                                <span class="field-label">Purpose</span>
                                <textarea class="inc-form__control" asp-for="Edit.Purpose" rows="4"></textarea>
                            </label>
                            <label class="inc-form__group">
                                <span class="field-label">Scope</span>
                                <textarea class="inc-form__control" asp-for="Edit.Scope" rows="4"></textarea>
                            </label>
                            <label class="inc-form__group">
                                <span class="field-label">Context</span>
                                <textarea class="inc-form__control" asp-for="Edit.Context" rows="5"></textarea>
                            </label>
                        </div>
                    </section>

                    <section class="inc-card editor-section">
                        <div class="editor-section-head">
                            <h4>Requirements</h4>
                            <span class="muted">Enter canonical REQ-... blocks with an immediate clause and optional Trace/Notes sections.</span>
                        </div>
                        <label class="inc-form__group">
                            <span class="field-label">Requirement clauses</span>
                            <textarea class="inc-form__control" asp-for="Edit.Requirements" rows="20"></textarea>
                        </label>
                    </section>

                    <section class="inc-card editor-section">
                        <div class="editor-section-head">
                            <h4>Related artifacts</h4>
                            <span class="muted">Optional artifact IDs that should be linked from the specification front matter.</span>
                        </div>
                        <label class="inc-form__group">
                            <span class="field-label">Related artifacts</span>
                            <textarea class="inc-form__control mono" asp-for="Edit.RelatedArtifacts" rows="6" placeholder="ARC-PAY-ACH-0002"></textarea>
                        </label>
                    </section>

                    <section class="inc-card editor-section">
                        <div class="editor-section-head">
                            <h4>Open questions</h4>
                            <span class="muted">Keep unresolved items visible instead of burying them in prose.</span>
                        </div>
                        <label class="inc-form__group">
                            <span class="field-label">Open questions</span>
                            <textarea class="inc-form__control" asp-for="Edit.OpenQuestions" rows="4"></textarea>
                        </label>
                    </section>

                    <div class="button-row">
                        <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">@(Model.IsCreateMode ? "Create spec" : "Save spec")</button>
                    </div>
                </form>
            </section>

            @if (!Model.IsCreateMode)
            {
                <section class="doc-viewer">
                    <div class="panel-head compact">
                        <h4>Rendered preview</h4>
                        <span class="muted">Current Markdown body</span>
                    </div>
                    <div class="markdown-body">
                        @Html.Raw(Model.SelectedSpecHtml)
                    </div>
                </section>
            }
        }
    </section>
</div>
