@page
@model Workbench.Pages.SpecsModel
@{
    ViewData["Title"] = "Specs";
}

<inc-card class="hero">
    <div class="hero-copy">
        <div class="eyebrow">Specification editor</div>
        <h2>Write and manage repository-native specifications with schema-backed metadata, canonical requirement clauses, and stable IDs.</h2>
        <p>
            Specifications stay Markdown-first, but the editor keeps required fields explicit and lets you reorder optional tags and related artifacts so the form mirrors the front-matter schema.
        </p>
        <div class="muted">@Model.SpecIdPolicySummary</div>
        <div class="hero-links">
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Specs" asp-route-createMode="true" asp-route-query="@Model.Query">Create spec</a>
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Docs">Docs</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Index">Items</a>
        </div>
    </div>
    <div class="hero-stats">
        <inc-card class="stat-card accent">
            <span class="stat-label">Specs found</span>
            <span class="stat-value">@Model.Specs.Count</span>
        </inc-card>
        <inc-card class="stat-card">
            <span class="stat-label">Query</span>
            <span class="stat-value">@(string.IsNullOrWhiteSpace(Model.Query) ? "all" : Model.Query)</span>
        </inc-card>
        <inc-card class="stat-card">
            <span class="stat-label">Repo root</span>
            <span class="stat-value">@Model.RepoRoot</span>
        </inc-card>
        <inc-card class="stat-card">
            <span class="stat-label">Profile</span>
            <span class="stat-value">@Model.ProfileName</span>
        </inc-card>
    </div>
</inc-card>

@if (!string.IsNullOrWhiteSpace(Model.BannerTitle))
{
    <inc-card class="panel banner">
        <div class="panel-head compact">
            <h3>@Model.BannerTitle</h3>
        </div>
        @foreach (var line in Model.BannerLines)
        {
            <div class="muted">@line</div>
        }
    </inc-card>
}

<div class="workspace docs-layout">
    <inc-card class="panel sidebar">
        <div class="panel-head">
            <h3>Browse specs</h3>
            <form method="get" class="inline-filter docs-filter">
                <input type="hidden" name="selectedReference" value="@Model.SelectedReference" />
                <input type="hidden" name="createMode" value="@Model.CreateMode" />
                <inc-field label="Search">
                    <input class="inc-form__control" name="query" value="@Model.Query" placeholder="Artifact ID, title, body, tag, related artifact" />
                </inc-field>
                <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Apply filters</button>
            </form>
        </div>

        <div class="tree-list">
            @if (Model.Specs.Count == 0)
            {
                <div class="empty-state">No specs match the current filters.</div>
            }
            else
            {
                @await Html.PartialAsync("_TreeBranch", Model.Tree)
            }
        </div>
    </inc-card>

    <inc-card class="panel detail">
        @if (Model.SelectedSpec is null && !Model.IsCreateMode)
        {
            <div class="empty-state large">Select a spec to edit it here or start a new one with the create button above.</div>
        }
        else
        {
            <div class="detail-header">
                <div>
                    <div class="eyebrow">@(Model.IsCreateMode ? "Create spec" : "Selected spec")</div>
                    <h3>@(Model.IsCreateMode ? "Create a new specification" : Model.Edit.Title)</h3>
                    <p>@(Model.IsCreateMode ? "Workbench will save the new specification under specs/requirements/<domain>/ unless you choose a path." : Model.SelectedSpec!.Summary.Path)</p>
                </div>
                <div class="detail-badges">
                    @if (Model.IsCreateMode)
                    {
                        <span class="pill">specification</span>
                        <span class="pill">create</span>
                    }
                    else
                    {
                        <span class="pill">@Model.SelectedSpec!.Summary.ArtifactId</span>
                        <span class="pill">@Model.SelectedSpec!.Summary.Status</span>
                    }
                </div>
            </div>

            <inc-card class="snapshot">
                <div class="snapshot-head">
                    <h4>@(Model.IsCreateMode ? "Creation hints" : "Metadata")</h4>
                    <span class="muted">@Model.SpecIdPolicySummary</span>
                </div>
                <div class="link-grid">
                    <div>
                        <div class="field-label">Artifact ID</div>
                        @{
                            var artifactIdDisplay = Model.Edit.ArtifactId;
                            if (string.IsNullOrWhiteSpace(artifactIdDisplay))
                            {
                                artifactIdDisplay = Model.IsCreateMode ? "- (generated on save if policy applies)" : "-";
                            }
                        }
                        <div class="mono">@artifactIdDisplay</div>
                    </div>
                    <div>
                        <div class="field-label">Domain</div>
                        <div class="mono">@(string.IsNullOrWhiteSpace(Model.Edit.Domain) ? "-" : Model.Edit.Domain)</div>
                    </div>
                    <div>
                        <div class="field-label">Capability</div>
                        <div class="mono">@(string.IsNullOrWhiteSpace(Model.Edit.Capability) ? "-" : Model.Edit.Capability)</div>
                    </div>
                    <div>
                        <div class="field-label">Tags</div>
                        @if (Model.IsCreateMode)
                        {
                            <div class="muted">Draft tags will appear after save.</div>
                        }
                        else if (Model.SelectedSpec!.Summary.Tags.Count == 0)
                        {
                            <div class="muted">None</div>
                        }
                        else
                        {
                            <div class="detail-badges">
                                @foreach (var tag in Model.SelectedSpec.Summary.Tags)
                                {
                                    <span class="pill">@tag</span>
                                }
                            </div>
                        }
                    </div>
                    <div>
                        <div class="field-label">Related artifacts</div>
                        @if (Model.IsCreateMode)
                        {
                            <div class="muted">Draft links will appear after save.</div>
                        }
                        else if (Model.SelectedSpec!.Summary.RelatedArtifacts.Count == 0)
                        {
                            <div class="muted">None</div>
                        }
                        else
                        {
                            foreach (var id in Model.SelectedSpec.Summary.RelatedArtifacts)
                            {
                                <div class="mono">@id</div>
                            }
                        }
                    </div>
                    <div>
                        <div class="field-label">Path</div>
                        <div class="mono">@(Model.IsCreateMode ? "specs/requirements/<DOMAIN>/SPEC-<DOMAIN>-....md" : Model.SelectedSpec!.Summary.Path)</div>
                    </div>
                    @if (!Model.IsCreateMode)
                    {
                        <div>
                            <div class="field-label">Excerpt</div>
                            <div class="muted">@Model.SelectedSpec!.Summary.Excerpt</div>
                        </div>
                    }
                </div>
            </inc-card>

            <form method="post" asp-page-handler="Save" class="editor-stack">
                <partial name="_ValidationSummary" />
                <input type="hidden" asp-for="CreateMode" />
                <input type="hidden" asp-for="Edit.Path" />

                <inc-disclosure class="inc-card editor-section" summary="Identity" open>
                    <div slot="content" class="editor-grid editor-grid-two">
                        <inc-field label="Artifact ID">
                            <input class="inc-form__control mono" asp-for="Edit.ArtifactId" placeholder="SPEC-CLI-ONBOARDING" />
                        </inc-field>
                        <inc-field label="Domain">
                            <input class="inc-form__control mono" asp-for="Edit.Domain" placeholder="CLI" required />
                        </inc-field>
                        <inc-field label="Capability">
                            <input class="inc-form__control mono" asp-for="Edit.Capability" placeholder="ONBOARDING" required />
                        </inc-field>
                        <inc-field label="Status">
                            <input class="inc-form__control" asp-for="Edit.Status" placeholder="draft" required />
                        </inc-field>
                        <inc-field class="span-2" label="Title">
                            <input class="inc-form__control" asp-for="Edit.Title" required />
                        </inc-field>
                        <inc-field class="span-2" label="Owner">
                            <input class="inc-form__control" asp-for="Edit.Owner" placeholder="team or person" required />
                        </inc-field>
                    </div>
                </inc-disclosure>

                <inc-disclosure class="inc-card editor-section" summary="Core narrative" open>
                    <div slot="content" class="editor-stack">
                        <inc-field label="Purpose">
                            <textarea class="inc-form__control" asp-for="Edit.Purpose" rows="4"></textarea>
                        </inc-field>
                        <inc-field label="Scope">
                            <textarea class="inc-form__control" asp-for="Edit.Scope" rows="4"></textarea>
                        </inc-field>
                        <inc-field label="Context">
                            <textarea class="inc-form__control" asp-for="Edit.Context" rows="5"></textarea>
                        </inc-field>
                    </div>
                </inc-disclosure>

                <inc-disclosure class="inc-card editor-section" summary="Requirements" open>
                    <div slot="content">
                        <inc-field label="Requirement clauses">
                            <textarea class="inc-form__control" asp-for="Edit.Requirements" rows="20"></textarea>
                        </inc-field>
                    </div>
                </inc-disclosure>

                <inc-disclosure class="inc-card editor-section" summary="Schema metadata" open>
                    <div slot="content" class="editor-stack">
                        <div class="inc-form__field" data-array-editor data-array-label="Tag">
                            <span class="inc-form__label">Tags</span>
                            <span class="inc-form__hint">Topical tags improve search and navigation. Use the controls to add, remove, and reorder entries.</span>
                            <input type="hidden" asp-for="Edit.Tags" data-array-input data-array-placeholder="release" />
                            <div class="array-editor__list" data-array-list></div>
                            <button type="button" class="inc-btn inc-btn--secondary inc-btn--sm" data-array-action="add">Add tag</button>
                        </div>

                        <div class="inc-form__field" data-array-editor data-array-label="Related artifact">
                            <span class="inc-form__label">Related artifacts</span>
                            <span class="inc-form__hint">Add SPEC, ARC, WI, or VER IDs one per line. Use the controls to add, remove, and reorder entries.</span>
                            <input type="hidden" asp-for="Edit.RelatedArtifacts" data-array-input data-array-placeholder="ARC-PAY-ACH-0002" />
                            <div class="array-editor__list" data-array-list></div>
                            <button type="button" class="inc-btn inc-btn--secondary inc-btn--sm" data-array-action="add">Add artifact</button>
                        </div>
                    </div>
                </inc-disclosure>

                <inc-disclosure class="inc-card editor-section" summary="Open questions" open>
                    <div slot="content">
                        <inc-field label="Open questions">
                            <textarea class="inc-form__control" asp-for="Edit.OpenQuestions" rows="4"></textarea>
                        </inc-field>
                    </div>
                </inc-disclosure>

                <div class="button-row">
                    <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">@(Model.IsCreateMode ? "Create spec" : "Save spec")</button>
                </div>
            </form>

            @if (!Model.IsCreateMode)
            {
                <inc-disclosure class="doc-viewer" summary="Rendered preview" open>
                    <div slot="content" class="markdown-body">
                        @Html.Raw(Model.SelectedSpecHtml)
                    </div>
                </inc-disclosure>
            }
        }
    </inc-card>
</div>
