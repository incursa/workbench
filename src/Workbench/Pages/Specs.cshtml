@page
@model Workbench.Pages.SpecsModel
@{
    ViewData["Title"] = "Specs";
}

<div class="inc-stack inc-stack--gap-lg">
    @if (!string.IsNullOrWhiteSpace(Model.BannerTitle))
    {
        <section class="inc-state-panel inc-state-panel--results">
            <div class="inc-state-panel__head">
                <div class="inc-state-panel__icon">i</div>
                <div>
                    <h2 class="inc-state-panel__title">@Model.BannerTitle</h2>
                    @foreach (var line in Model.BannerLines)
                    {
                        <p class="inc-state-panel__body">@line</p>
                    }
                </div>
            </div>
        </section>
    }

    <div class="inc-grid inc-grid--cols-2 inc-grid--gap-lg">
        <aside class="inc-card inc-stack inc-stack--gap-lg">
            <div class="inc-stack inc-stack--gap-sm">
                <div>
                    <p class="inc-key-value__label">Catalog</p>
                    <h2>Specifications</h2>
                    <p>Browse schema-backed specifications and open one to edit repo-native files directly.</p>
                </div>
                <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Specs" asp-route-createMode="true" asp-route-selectedReference="new" asp-route-query="@Model.Query">New spec</a>
            </div>

            <form method="get" class="inc-filter-bar">
                <input type="hidden" name="selectedReference" value="@Model.SelectedReference" />
                <input type="hidden" name="createMode" value="false" />
                <div class="inc-filter-bar__main">
                    <label class="inc-form__group inc-filter-bar__field inc-filter-bar__field--grow">
                        <span class="inc-form__label">Search</span>
                        <input class="inc-form__control" name="query" value="@Model.Query" placeholder="Artifact ID, title, requirement, related artifact" />
                        <span class="inc-form__hint">Filter by artifact ID, title, requirement text, or linked artifacts.</span>
                    </label>
                </div>
                <div class="inc-filter-bar__actions">
                    <button type="submit" class="inc-btn inc-btn--secondary inc-btn--sm">Apply</button>
                </div>
            </form>

            @if (Model.Specs.Count == 0)
            {
                <div class="inc-empty-state">
                    <div class="inc-empty-state__content">
                        <div class="inc-empty-state__icon">?</div>
                        <h3 class="inc-heading inc-heading--h3">No specifications</h3>
                        <p class="inc-text inc-text--regular inc-text--muted">No specifications match the current filters.</p>
                    </div>
                </div>
            }
            else
            {
                @await Html.PartialAsync("_TreeBranch", Model.Tree)
            }
        </aside>

        <div class="inc-stack inc-stack--gap-lg">
            <section class="inc-card inc-stack inc-stack--gap-lg">
                <div class="inc-stack inc-stack--gap-sm">
                    <div>
                        <p class="inc-key-value__label">@(Model.IsCreateMode ? "Create specification" : "Edit specification")</p>
                        <h2>@(Model.IsCreateMode ? "Schema-backed specification editor" : Model.Edit.Title)</h2>
                        <p>@Model.SpecIdPolicySummary</p>
                    </div>
                </div>

                <div class="inc-key-value-grid">
                    <div class="inc-key-value inc-key-value--card">
                        <div class="inc-key-value__label">Path</div>
                        <div class="inc-key-value__value inc-key-value__value--data">@Model.PathPreview</div>
                    </div>
                    <div class="inc-key-value inc-key-value--card">
                        <div class="inc-key-value__label">Format</div>
                        <div class="inc-key-value__value">@Model.Edit.SourceFormat</div>
                    </div>
                    <div class="inc-key-value inc-key-value--card">
                        <div class="inc-key-value__label">Visible specs</div>
                        <div class="inc-key-value__value">@Model.Specs.Count</div>
                    </div>
                </div>

                @if (Model.IsLegacyMarkdownSpec)
                {
                    <section class="inc-state-panel inc-state-panel--results">
                        <div class="inc-state-panel__head">
                            <div class="inc-state-panel__icon">M</div>
                            <div>
                                <h3 class="inc-state-panel__title">Markdown-backed source</h3>
                                <p class="inc-state-panel__body">This file still saves as Markdown. The editor stays structured, but Workbench will preserve the existing Markdown format until the artifact is migrated to canonical JSON.</p>
                            </div>
                        </div>
                    </section>
                }

                <form method="post" asp-page-handler="Save" class="inc-stack inc-stack--gap-lg">
                    <partial name="_ValidationSummary" />
                    <input type="hidden" asp-for="CreateMode" />
                    <input type="hidden" asp-for="SelectedReference" />
                    <input type="hidden" asp-for="Query" />
                    <input type="hidden" asp-for="Edit.Path" />
                    <input type="hidden" asp-for="Edit.SourceFormat" />
                    <input type="hidden" asp-for="Edit.SchemaReference" />
                    <input type="hidden" asp-for="Edit.ExtensionJson" />

                    <inc-disclosure class="inc-card" summary="Artifact" open>
                        <div slot="content" class="inc-stack inc-stack--gap-md">
                            <div class="inc-grid inc-grid--cols-2 inc-grid--gap-md">
                                <inc-field label="Artifact ID">
                                    <input class="inc-form__control mono" asp-for="Edit.ArtifactId" placeholder="SPEC-PAY-ACH" />
                                </inc-field>
                                <inc-field label="Domain">
                                    <input class="inc-form__control mono" asp-for="Edit.Domain" placeholder="payments" />
                                </inc-field>
                            </div>

                            <div class="inc-grid inc-grid--cols-2 inc-grid--gap-md">
                                <inc-field label="Capability">
                                    <input class="inc-form__control" asp-for="Edit.Capability" placeholder="ach-transfers" />
                                </inc-field>
                                <inc-field label="Status">
                                    <input class="inc-form__control" asp-for="Edit.Status" placeholder="draft" />
                                </inc-field>
                            </div>

                            <inc-field label="Title">
                                <input class="inc-form__control" asp-for="Edit.Title" />
                            </inc-field>

                            <inc-field label="Owner">
                                <input class="inc-form__control" asp-for="Edit.Owner" placeholder="team or maintainer" />
                            </inc-field>
                        </div>
                    </inc-disclosure>

                    <inc-disclosure class="inc-card" summary="Narrative" open>
                        <div slot="content" class="inc-stack inc-stack--gap-md">
                            <inc-field label="Purpose">
                                <textarea class="inc-form__control" asp-for="Edit.Purpose" rows="4"></textarea>
                            </inc-field>
                            <inc-field label="Scope">
                                <textarea class="inc-form__control" asp-for="Edit.Scope" rows="4"></textarea>
                            </inc-field>
                            <inc-field label="Context">
                                <textarea class="inc-form__control" asp-for="Edit.Context" rows="5"></textarea>
                            </inc-field>
                        </div>
                    </inc-disclosure>

                    <inc-disclosure class="inc-card" summary="Requirements" open>
                        <div slot="content" class="inc-stack inc-stack--gap-md">
                            <div>
                                <button type="submit" asp-page-handler="AddRequirement" formnovalidate class="inc-btn inc-btn--secondary inc-btn--sm">Add requirement</button>
                            </div>

                            @for (var i = 0; i < Model.Edit.Requirements.Count; i++)
                            {
                                <section class="inc-card inc-stack inc-stack--gap-md">
                                    <input type="hidden" asp-for="Edit.Requirements[i].ExtensionJson" />
                                    <input type="hidden" asp-for="Edit.Requirements[i].Trace.ExtensionJson" />

                                    <div class="inc-stack inc-stack--gap-sm">
                                        <div>
                                            <p class="inc-key-value__label">Requirement @(i + 1)</p>
                                            <h4>@(string.IsNullOrWhiteSpace(Model.Edit.Requirements[i].Id) ? "New requirement" : Model.Edit.Requirements[i].Id)</h4>
                                        </div>
                                        <div>
                                            <button type="submit" asp-page-handler="RemoveRequirement" name="index" value="@i" formnovalidate class="inc-btn inc-btn--secondary inc-btn--sm">Remove</button>
                                        </div>
                                    </div>

                                    <div class="inc-grid inc-grid--cols-2 inc-grid--gap-md">
                                        <inc-field label="Requirement ID">
                                            <input class="inc-form__control mono" asp-for="Edit.Requirements[i].Id" placeholder="REQ-PAY-ACH-0001" />
                                        </inc-field>
                                        <inc-field label="Title">
                                            <input class="inc-form__control" asp-for="Edit.Requirements[i].Title" />
                                        </inc-field>
                                    </div>

                                    <inc-field label="Statement">
                                        <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Statement" rows="3"></textarea>
                                    </inc-field>

                                    <inc-field label="Notes">
                                        <textarea class="inc-form__control" asp-for="Edit.Requirements[i].NotesText" rows="3" placeholder="One note per line"></textarea>
                                    </inc-field>

                                    <div class="inc-grid inc-grid--cols-3 inc-grid--gap-md">
                                        <inc-field label="Satisfied By">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.SatisfiedByText" rows="2" placeholder="ARC-... one per line"></textarea>
                                        </inc-field>
                                        <inc-field label="Implemented By">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.ImplementedByText" rows="2" placeholder="WI-... one per line"></textarea>
                                        </inc-field>
                                        <inc-field label="Verified By">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.VerifiedByText" rows="2" placeholder="VER-... one per line"></textarea>
                                        </inc-field>
                                        <inc-field label="Derived From">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.DerivedFromText" rows="2" placeholder="REQ-... one per line"></textarea>
                                        </inc-field>
                                        <inc-field label="Supersedes">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.SupersedesText" rows="2" placeholder="REQ-... one per line"></textarea>
                                        </inc-field>
                                        <inc-field label="Upstream Refs">
                                            <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.UpstreamRefsText" rows="2" placeholder="External refs, one per line"></textarea>
                                        </inc-field>
                                    </div>

                                    <inc-field label="Related">
                                        <textarea class="inc-form__control" asp-for="Edit.Requirements[i].Trace.RelatedText" rows="2" placeholder="SPEC/ARC/WI/VER IDs, one per line"></textarea>
                                    </inc-field>
                                </section>
                            }
                        </div>
                    </inc-disclosure>

                    <inc-disclosure class="inc-card" summary="Supplemental Sections" open>
                        <div slot="content" class="inc-stack inc-stack--gap-md">
                            <div>
                                <button type="submit" asp-page-handler="AddSupplementalSection" formnovalidate class="inc-btn inc-btn--secondary inc-btn--sm">Add section</button>
                            </div>

                            @if (Model.Edit.SupplementalSections.Count == 0)
                            {
                                <div class="inc-empty-state">
                                    <div class="inc-empty-state__content">
                                        <div class="inc-empty-state__icon">+</div>
                                        <h3 class="inc-heading inc-heading--h3">No supplemental sections</h3>
                                        <p class="inc-text inc-text--regular inc-text--muted">Add optional sections only when the schema needs extra narrative beyond purpose, scope, context, and requirements.</p>
                                    </div>
                                </div>
                            }
                            else
                            {
                                @for (var i = 0; i < Model.Edit.SupplementalSections.Count; i++)
                                {
                                    <section class="inc-card inc-stack inc-stack--gap-md">
                                        <input type="hidden" asp-for="Edit.SupplementalSections[i].ExtensionJson" />

                                        <div class="inc-stack inc-stack--gap-sm">
                                            <div>
                                                <p class="inc-key-value__label">Section @(i + 1)</p>
                                                <h4>@(string.IsNullOrWhiteSpace(Model.Edit.SupplementalSections[i].Heading) ? "Untitled section" : Model.Edit.SupplementalSections[i].Heading)</h4>
                                            </div>
                                            <div>
                                                <button type="submit" asp-page-handler="RemoveSupplementalSection" name="index" value="@i" formnovalidate class="inc-btn inc-btn--secondary inc-btn--sm">Remove</button>
                                            </div>
                                        </div>

                                        <inc-field label="Heading">
                                            <input class="inc-form__control" asp-for="Edit.SupplementalSections[i].Heading" />
                                        </inc-field>

                                        <inc-field label="Content">
                                            <textarea class="inc-form__control" asp-for="Edit.SupplementalSections[i].Content" rows="4"></textarea>
                                        </inc-field>
                                    </section>
                                }
                            }
                        </div>
                    </inc-disclosure>

                    <inc-disclosure class="inc-card" summary="Artifact Links" open>
                        <div slot="content" class="inc-stack inc-stack--gap-md">
                            <div class="inc-grid inc-grid--cols-2 inc-grid--gap-md">
                                <inc-field label="Tags">
                                    <textarea class="inc-form__control" asp-for="Edit.TagsText" rows="3" placeholder="One tag per line"></textarea>
                                </inc-field>
                                <inc-field label="Related Artifacts">
                                    <textarea class="inc-form__control" asp-for="Edit.RelatedArtifactsText" rows="3" placeholder="SPEC/ARC/WI/VER IDs, one per line"></textarea>
                                </inc-field>
                            </div>

                            <inc-field label="Open Questions">
                                <textarea class="inc-form__control" asp-for="Edit.OpenQuestionsText" rows="3" placeholder="One question per line"></textarea>
                            </inc-field>
                        </div>
                    </inc-disclosure>

                    <div>
                        <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">@(Model.IsCreateMode ? "Create spec" : "Save spec")</button>
                        @if (!Model.IsCreateMode && Model.SelectedSpec is not null)
                        {
                            <button type="submit" asp-page-handler="Delete" formnovalidate class="inc-btn inc-btn--secondary inc-btn--sm">Delete</button>
                        }
                    </div>
                </form>
            </section>

            @if (Model.SelectedSpec is not null)
            {
                <section class="inc-card inc-stack inc-stack--gap-md">
                    <div>
                        <p class="inc-key-value__label">Stored Source</p>
                        <h3>@Model.SelectedSpec.Summary.Path</h3>
                    </div>
                    <pre class="mono">@Model.SelectedSpecSource</pre>
                </section>
            }
        </div>
    </div>
</div>
