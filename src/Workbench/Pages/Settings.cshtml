@page
@model Workbench.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<section class="hero inc-card">
    <div class="hero-copy">
        <div class="eyebrow">Local identity</div>
        <h2>Store a machine-local authoring profile.</h2>
        <p>
            This is not an auth flow. It simply gives the browser UI a default name, handle, email, and work item owner for local authoring.
        </p>
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <inc-state-panel variant="success" title="Saved" body="@Model.Message"></inc-state-panel>
        }
    </div>
    <div class="hero-stats inc-summary-overview inc-summary-overview--4-col">
        <article class="inc-summary-block stat-card accent">
            <div class="inc-summary-block__header stat-label">Profile file</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--small stat-value">@Model.ProfilePath</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Display name</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@(string.IsNullOrWhiteSpace(Model.DisplayName) ? "unset" : Model.DisplayName)</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Default owner</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@(string.IsNullOrWhiteSpace(Model.DefaultOwner) ? "unset" : Model.DefaultOwner)</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Effective author</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@Model.EffectiveAuthorDisplay</div>
            </div>
        </article>
    </div>
</section>

<inc-card class="panel">
    <div class="panel-head compact">
        <h3>Edit profile</h3>
        <a class="muted" asp-page="/Index">Back to items</a>
    </div>

    <form method="post" class="editor-grid editor-grid-two">
        <inc-field label="Display name">
            <input class="inc-form__control" asp-for="DisplayName" placeholder="Sam McAravey" />
        </inc-field>
        <inc-field label="Handle">
            <input class="inc-form__control" asp-for="Handle" placeholder="sam" />
        </inc-field>
        <inc-field label="Email">
            <input class="inc-form__control" asp-for="Email" placeholder="sam@example.com" />
        </inc-field>
        <inc-field label="Default owner">
            <input class="inc-form__control" asp-for="DefaultOwner" placeholder="platform" />
        </inc-field>
        <div class="button-row span-2">
            <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Save profile</button>
        </div>
    </form>
</inc-card>
