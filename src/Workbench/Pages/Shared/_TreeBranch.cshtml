@model RepoTreeBranch

@{
    var branch = Model;
    while (branch.Children.Count == 1 && branch.Entries.Count == 0)
    {
        branch = branch.Children[0];
    }

    var isContainerOnly = string.IsNullOrWhiteSpace(branch.Path) && branch.Entries.Count == 0 && branch.Children.Count > 0;
}

@if (isContainerOnly)
{
    <div class="tree-children">
        @foreach (var child in branch.Children)
        {
            @await Html.PartialAsync("_TreeBranch", child)
        }
    </div>
}
else
{
    <details class="inc-card tree-branch" open>
        <summary class="tree-summary">
            <span class="tree-summary-title">@branch.Name</span>
            <span class="muted">@branch.EntryCount items</span>
        </summary>
        <div class="tree-children">
            @foreach (var child in branch.Children)
            {
                @await Html.PartialAsync("_TreeBranch", child)
            }

            @foreach (var entry in branch.Entries)
            {
                <a class="inc-card tree-entry @(entry.IsSelected ? "selected" : string.Empty)" href="@entry.Href">
                    <div class="inc-card__body">
                        <div class="tree-entry-top">
                            <span class="inc-badge inc-badge--pill inc-badge--info">@entry.Badge</span>
                        </div>
                        <div class="tree-entry-title">@entry.Title</div>
                        @if (!string.IsNullOrWhiteSpace(entry.Secondary))
                        {
                            <div class="tree-entry-meta">@entry.Secondary</div>
                        }
                    </div>
                </a>
            }
        </div>
    </details>
}
