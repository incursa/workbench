@model RepoTreeBranch

@{
    var branch = Model;
    while (branch.Children.Count == 1 && branch.Entries.Count == 0)
    {
        branch = branch.Children[0];
    }

    var isContainerOnly = string.IsNullOrWhiteSpace(branch.Path) && branch.Entries.Count == 0 && branch.Children.Count > 0;
}

@if (isContainerOnly)
{
    <div class="inc-stack inc-stack--gap-sm">
        @foreach (var child in branch.Children)
        {
            @await Html.PartialAsync("_TreeBranch", child)
        }
    </div>
}
else
{
    <details class="inc-disclosure" open>
        <summary class="inc-disclosure__summary">
            <span class="inc-disclosure__title">@branch.Name</span>
            <span class="inc-disclosure__meta">@branch.EntryCount items</span>
        </summary>
        <div class="inc-disclosure__content">
            <div class="inc-stack inc-stack--gap-sm">
            @foreach (var child in branch.Children)
            {
                @await Html.PartialAsync("_TreeBranch", child)
            }

            @foreach (var entry in branch.Entries)
            {
                <a class="inc-card text-decoration-none @(entry.IsSelected ? "border-primary" : string.Empty)" href="@entry.Href" aria-current="@(entry.IsSelected ? "page" : null)">
                    <div class="inc-card__body d-flex flex-column gap-1">
                        <div>
                            <span class="inc-badge inc-badge--pill inc-badge--info">@entry.Badge</span>
                        </div>
                        <div class="fw-semibold text-truncate">@entry.Title</div>
                        @if (!string.IsNullOrWhiteSpace(entry.Secondary))
                        {
                            <div class="small text-body-secondary text-truncate">@entry.Secondary</div>
                        }
                    </div>
                </a>
            }
            </div>
        </div>
    </details>
}
