@page
@model Workbench.Pages.FilesModel
@{
    ViewData["Title"] = "Files";
}

<section class="hero inc-card">
    <div class="hero-copy">
        <div class="eyebrow">Local file explorer</div>
        <h2>Browse the repo and preview markdown inline.</h2>
        <p>
            This page scans the local checkout, renders a nested folder navigator, and previews markdown or text files directly in the browser.
        </p>
        <div class="hero-links">
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Index">Items</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Docs">Docs browser</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Create">Create item</a>
        </div>
    </div>
    <div class="hero-stats">
        <div class="inc-card stat-card accent">
            <span class="stat-label">Files found</span>
            <span class="stat-value">@Model.Files.Count</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Markdown</span>
            <span class="stat-value">@Model.MarkdownCount</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Text</span>
            <span class="stat-value">@Model.TextCount</span>
        </div>
        <div class="inc-card stat-card">
            <span class="stat-label">Binary</span>
            <span class="stat-value">@Model.BinaryCount</span>
        </div>
    </div>
</section>

<div class="workspace files-layout">
    <aside class="inc-card panel sidebar">
        <div class="panel-head">
            <h3>Browse files</h3>
            <form method="get" class="inline-filter files-filter">
                <input type="hidden" name="selectedPath" value="@Model.SelectedPath" />
                <label class="inc-form__group">
                    <span class="field-label">Search</span>
                    <input class="inc-form__control" name="query" value="@Model.Query" placeholder="Path, name, excerpt, kind" />
                </label>
                <label class="inc-form__group">
                    <span class="field-label">Type</span>
                    <select class="inc-form__select" asp-for="TypeFilter">
                        @foreach (var type in global::Workbench.Pages.FilesModel.TypeOptions)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </label>
                <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Apply filters</button>
            </form>
        </div>

        <div class="tree-list">
            @if (Model.Files.Count == 0)
            {
                <div class="empty-state">No files match the current filters.</div>
            }
            else
            {
                @await Html.PartialAsync("_TreeBranch", Model.Tree)
            }
        </div>
    </aside>

    <section class="inc-card panel detail">
        @if (Model.SelectedFile is null)
        {
            <div class="empty-state large">Select a file to preview it here.</div>
        }
        else
        {
            <div class="detail-header">
                <div>
                    <div class="eyebrow">Selected file</div>
                    <h3>@Model.SelectedFile.Summary.Name</h3>
                    <p>@Model.SelectedFile.Summary.Path</p>
                </div>
                <div class="detail-badges">
                    <span class="pill">@Model.SelectedFile.Summary.FileType</span>
                    <span class="pill">@Model.SelectedFile.Summary.Extension</span>
                </div>
            </div>

            <section class="inc-card snapshot">
                <div class="snapshot-head">
                    <h4>Metadata</h4>
                    <span class="muted">@Model.SelectedFile.Summary.LastModifiedUtc.ToString("u")</span>
                </div>
                <div class="link-grid">
                    <div>
                        <div class="field-label">Size</div>
                        <div class="mono">@Model.SelectedFile.Summary.SizeBytes bytes</div>
                    </div>
                    <div>
                        <div class="field-label">Preview</div>
                        <div class="mono">@(Model.SelectedFile.CanPreview ? "available" : "binary file")</div>
                    </div>
                    <div class="span-2">
                        <div class="field-label">Excerpt</div>
                        <div class="muted">@Model.SelectedFile.Summary.Excerpt</div>
                    </div>
                </div>
            </section>

            <section class="doc-viewer">
                <div class="panel-head compact">
                    <h4>Preview</h4>
                    <span class="muted">Local read-only preview</span>
                </div>
                @if (Model.SelectedFile.IsBinary)
                {
                    <div class="empty-state">Binary files are listed here but not rendered inline.</div>
                }
                else if (Model.SelectedFile.IsMarkdown)
                {
                    <div class="markdown-body">
                        @Html.Raw(Model.SelectedFileHtml)
                    </div>
                }
                else
                {
                    <pre class="doc-body">@Model.SelectedFile.Body</pre>
                }
            </section>
        }
    </section>
</div>
