@page
@model Workbench.Pages.FilesModel
@{
    ViewData["Title"] = "Files";
}

<inc-card class="hero">
    <div class="hero-copy">
        <div class="eyebrow">Local file explorer</div>
        <h2>Browse the repo and preview markdown inline.</h2>
        <p>
            This page scans the local checkout, renders a nested folder navigator, and previews markdown or text files directly in the browser.
        </p>
        <div class="hero-links">
            <a class="inc-btn inc-btn--primary inc-btn--sm" asp-page="/Index">Items</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Docs">Docs browser</a>
            <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Create">Create item</a>
        </div>
    </div>
    <div class="hero-stats inc-summary-overview inc-summary-overview--4-col">
        <article class="inc-summary-block stat-card accent">
            <div class="inc-summary-block__header stat-label">Files found</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@Model.Files.Count</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Markdown</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@Model.MarkdownCount</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Text</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@Model.TextCount</div>
            </div>
        </article>
        <article class="inc-summary-block stat-card">
            <div class="inc-summary-block__header stat-label">Binary</div>
            <div class="inc-summary-block__body inc-summary-block__body--left">
                <div class="inc-summary-block__value inc-summary-block__value--large stat-value">@Model.BinaryCount</div>
            </div>
        </article>
    </div>
</inc-card>

<div class="workspace files-layout">
    <inc-card class="panel sidebar">
        <div class="panel-head">
            <h3>Browse files</h3>
            <form method="get" class="inc-filter-bar files-filter">
                <input type="hidden" name="selectedPath" value="@Model.SelectedPath" />
                <div class="inc-filter-bar__main">
                    <inc-field class="inc-filter-bar__field inc-filter-bar__field--grow" label="Search">
                        <input class="inc-form__control" name="query" value="@Model.Query" placeholder="Path, name, excerpt, kind" />
                    </inc-field>
                    <inc-field class="inc-filter-bar__field" label="Type">
                        <select class="inc-form__select" asp-for="TypeFilter">
                            @foreach (var type in global::Workbench.Pages.FilesModel.TypeOptions)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </inc-field>
                </div>
                <div class="inc-filter-bar__actions">
                    <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Apply filters</button>
                </div>
            </form>
        </div>

        <div class="tree-list">
            @if (Model.Files.Count == 0)
            {
                <div class="inc-empty-state">
                    <div class="inc-empty-state__content">
                        <div class="inc-empty-state__icon">?</div>
                        <h3 class="inc-heading inc-heading--h3">No files</h3>
                        <p class="inc-text inc-text--regular inc-text--muted">No files match the current filters.</p>
                    </div>
                </div>
            }
            else
            {
                @await Html.PartialAsync("_TreeBranch", Model.Tree)
            }
        </div>
    </inc-card>

    <inc-card class="panel detail">
        @if (Model.SelectedFile is null)
        {
            <div class="inc-empty-state">
                <div class="inc-empty-state__content">
                    <div class="inc-empty-state__icon">i</div>
                    <h3 class="inc-heading inc-heading--h3">Select a file</h3>
                    <p class="inc-text inc-text--regular inc-text--muted">Choose a file on the left to preview it here.</p>
                </div>
            </div>
        }
        else
        {
            <div class="detail-header">
                <div>
                    <div class="eyebrow">Selected file</div>
                    <h3>@Model.SelectedFile.Summary.Name</h3>
                    <p>@Model.SelectedFile.Summary.Path</p>
                </div>
                <div class="detail-badges">
                    <span class="inc-badge inc-badge--pill @Workbench.Pages.FilesModel.FileTypeBadgeClass(Model.SelectedFile.Summary.FileType)">@Model.SelectedFile.Summary.FileType</span>
                    <span class="inc-badge inc-badge--pill inc-badge--info">@Model.SelectedFile.Summary.Extension</span>
                </div>
            </div>

            <inc-card class="snapshot">
                <div class="snapshot-head">
                    <h4>Metadata</h4>
                    <span class="muted">@Model.SelectedFile.Summary.LastModifiedUtc.ToString("u")</span>
                </div>
                <div class="link-grid">
                    <div>
                        <div class="field-label">Size</div>
                        <div class="mono">@Model.SelectedFile.Summary.SizeBytes bytes</div>
                    </div>
                    <div>
                        <div class="field-label">Preview</div>
                        <div class="mono">@(Model.SelectedFile.CanPreview ? "available" : "binary file")</div>
                    </div>
                    <div class="span-2">
                        <div class="field-label">Excerpt</div>
                        <div class="muted">@Model.SelectedFile.Summary.Excerpt</div>
                    </div>
                </div>
            </inc-card>

            <inc-disclosure class="doc-viewer" summary="Preview" open>
                <div slot="summary" class="panel-head compact">
                    <h4>Preview</h4>
                    <span class="muted">Local read-only preview</span>
                </div>
                <div slot="content">
                    @if (Model.SelectedFile.IsBinary)
                    {
                        <div class="inc-empty-state">
                            <div class="inc-empty-state__content">
                                <div class="inc-empty-state__icon">B</div>
                                <h3 class="inc-heading inc-heading--h3">Binary file</h3>
                                <p class="inc-text inc-text--regular inc-text--muted">Binary files are listed here but not rendered inline.</p>
                            </div>
                        </div>
                    }
                    else if (Model.SelectedFile.IsMarkdown)
                    {
                        <div class="markdown-body">
                            @Html.Raw(Model.SelectedFileHtml)
                        </div>
                    }
                    else
                    {
                        <pre class="doc-body">@Model.SelectedFile.Body</pre>
                    }
                </div>
            </inc-disclosure>
        }
    </inc-card>
</div>
