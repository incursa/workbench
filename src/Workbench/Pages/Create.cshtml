@page
@model Workbench.Pages.CreateModel
@{
    ViewData["Title"] = "Create";
    ViewData["DisableCustomStyles"] = true;
}

<div class="inc-stack inc-stack--gap-lg">
    <section class="inc-card">
        <div class="inc-card__body inc-stack inc-stack--gap-lg">
            <div class="d-flex flex-column flex-xl-row justify-content-between gap-4">
                <div class="inc-stack inc-stack--gap-sm flex-grow-1">
                    <div>
                        <p class="inc-key-value__label mb-1">New work item</p>
                        <h2 class="mb-2">Create a repo-native item in one place.</h2>
                        <p class="mb-0">Use this page for new items so the editor stays focused on creation instead of mixing it with the item browser.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Index">Back to items</a>
                        <a class="inc-btn inc-btn--secondary inc-btn--sm" asp-page="/Docs">Docs</a>
                    </div>
                </div>

                <div class="inc-summary-overview inc-summary-overview--4-col flex-grow-1">
                    <article class="inc-summary-block">
                        <div class="inc-summary-block__header">Type</div>
                        <div class="inc-summary-block__body inc-summary-block__body--left">
                            <div class="inc-summary-block__value inc-summary-block__value--large">work_item</div>
                        </div>
                    </article>
                    <article class="inc-summary-block">
                        <div class="inc-summary-block__header">Default status</div>
                        <div class="inc-summary-block__body inc-summary-block__body--left">
                            <div class="inc-summary-block__value inc-summary-block__value--large">planned</div>
                        </div>
                    </article>
                    <article class="inc-summary-block">
                        <div class="inc-summary-block__header">Owner</div>
                        <div class="inc-summary-block__body inc-summary-block__body--left">
                            <div class="inc-summary-block__value inc-summary-block__value--large">local profile</div>
                        </div>
                    </article>
                    <article class="inc-summary-block">
                        <div class="inc-summary-block__header">Mode</div>
                        <div class="inc-summary-block__body inc-summary-block__body--left">
                            <div class="inc-summary-block__value inc-summary-block__value--large">local</div>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="inc-card">
        <div class="inc-card__body inc-stack inc-stack--gap-lg">
            <div>
                <p class="inc-key-value__label mb-1">Create item</p>
                <h3 class="mb-2">New work item</h3>
                <p class="mb-0">Uses the same file-backed work item service as the editor.</p>
            </div>

            <form method="post" class="inc-stack inc-stack--gap-lg">
                <partial name="_ValidationSummary" />
                <input type="hidden" asp-for="Create.Type" />

                <section class="inc-card">
                    <div class="inc-card__body inc-stack inc-stack--gap-md">
                        <div>
                            <h4 class="mb-1">Identity</h4>
                            <p class="mb-0 text-body-secondary">New item metadata and ownership.</p>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="inc-form__group mb-0">
                                    <label class="inc-form__label">Type</label>
                                    <input class="inc-form__control" value="work_item" readonly />
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="inc-form__group mb-0">
                                    <label class="inc-form__label" asp-for="Create.Owner">Owner / team</label>
                                    <input class="inc-form__control" asp-for="Create.Owner" placeholder="optional team or person" />
                                    <span class="inc-form__feedback inc-form__feedback--error" asp-validation-for="Create.Owner"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="inc-form__group mb-0">
                                    <label class="inc-form__label" asp-for="Create.Title">Title</label>
                                    <input class="inc-form__control" asp-for="Create.Title" />
                                    <span class="inc-form__feedback inc-form__feedback--error" asp-validation-for="Create.Title"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="inc-card">
                    <div class="inc-card__body inc-stack inc-stack--gap-md">
                        <div>
                            <h4 class="mb-1">Workflow</h4>
                            <p class="mb-0 text-body-secondary">Initial state and priority.</p>
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <div class="inc-form__group mb-0">
                                    <label class="inc-form__label" asp-for="Create.Status">Status</label>
                                    <select class="inc-form__select" asp-for="Create.Status">
                                        @foreach (var status in StatusOptions)
                                        {
                                            <option value="@status">@Workbench.Pages.IndexModel.StatusLabel(status)</option>
                                        }
                                    </select>
                                    <span class="inc-form__feedback inc-form__feedback--error" asp-validation-for="Create.Status"></span>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="inc-form__group mb-0">
                                    <label class="inc-form__label" asp-for="Create.Priority">Priority</label>
                                    <select class="inc-form__select" asp-for="Create.Priority">
                                        @foreach (var priority in PriorityOptions)
                                        {
                                            <option value="@priority">@(string.IsNullOrWhiteSpace(priority) ? "unset" : priority)</option>
                                        }
                                    </select>
                                    <span class="inc-form__feedback inc-form__feedback--error" asp-validation-for="Create.Priority"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="inc-btn inc-btn--primary inc-btn--sm">Create item</button>
                </div>
            </form>
        </div>
    </section>
</div>
